<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LetterStomach.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:LetterStomach.Views"
    BackgroundColor="{StaticResource PrimaryColor}"
    Shell.FlyoutBehavior="Flyout"
    Title="LetterStomach">

    <Shell.FlyoutHeader>
        <StackLayout BackgroundColor="{StaticResource FabColor}">
            <Grid ColumnDefinitions="0.9*,0.1*">
                <Label Text="Welcome to Letter Bot!"
                    FontSize="15"
                    HorizontalOptions="Start"
                    Margin="80, 200, 0, 0"
                    FontAttributes="Bold"
                    TextColor="{StaticResource SecondaryColor}" />
                <Image Source="automation_62dp_letter.png"
                    HorizontalOptions="End"
                    HeightRequest="62"
                    Margin="0, 162, 0, 20" />
            </Grid>
        </StackLayout>
    </Shell.FlyoutHeader>

    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid ColumnDefinitions="0.2*,0.9*" >
                <Image 
                    Source="{Binding FlyoutIcon}"
                    HeightRequest="62"
                    Margin="5" />
                <Label 
                    Grid.Column="1"
                    Text="{Binding Title}"
                    FontAttributes="Bold"
                    FontSize="18"
                    HorizontalTextAlignment="Start"
                    Margin="20, 0, 0, 0"
                    VerticalTextAlignment="Center"/>
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <FlyoutItem 
        Title="Home" 
        Icon="home_app_logo_62dp_letter.png">
        <ShellContent 
            Route="HomeView"
            ContentTemplate="{DataTemplate views:HomeView}"/>
    </FlyoutItem>
    <FlyoutItem 
        Title="Bot" 
        Icon="contacts_product_62dp_letter.png">
        <ShellContent 
            Route="BotView"
            ContentTemplate="{DataTemplate views:BotView}"/>
    </FlyoutItem>
    <FlyoutItem 
        Title="Exit" 
        Icon="exit_to_app_62dp_letter.png">
        <ShellContent 
            Route="ExitView"
            ContentTemplate="{DataTemplate views:ExitView}"/>
    </FlyoutItem>
</Shell>
