<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LetterStomach.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:LetterStomach.Views"
    xmlns:viewmodels="clr-namespace:LetterStomach.ViewModels"
    xmlns:locals="clr-namespace:LetterStomach"
    Shell.FlyoutBehavior="Flyout"
    BackgroundColor="{StaticResource LetterColor}"
    Title="LetterStomach">

    <Shell.MenuItemTemplate>
        <DataTemplate>
            <Grid 
                HeightRequest="60" 
                Padding="10" 
                ColumnDefinitions="0.2*,0.9*"
                Background="{StaticResource WhiteColor}">
                <Grid 
                    Grid.Column="0">
                    <Image
                        Source="{Binding FlyoutIcon}"
                        HeightRequest="62"
                        Margin="5" />
                </Grid>
                <Grid 
                    Grid.Column="1">
                    <Label 
                        Text="{Binding Title}" 
                        TextColor="{StaticResource BackgroundColor}" 
                        FontSize="18"
                        FontAttributes="None"
                        HorizontalTextAlignment="Start"
                        Margin="20, 0, 0, 0"
                        VerticalOptions="Center"/>
                </Grid>
            </Grid>
        </DataTemplate>
    </Shell.MenuItemTemplate>
    
    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid 
                Padding="10" 
                HeightRequest="60" 
                ColumnDefinitions="0.2*,0.9*" >
                <Grid 
                    Grid.Column="0">
                    <Image 
                        Source="{Binding FlyoutIcon}"
                        HeightRequest="62"
                        Margin="5" />
                </Grid>
                <Grid 
                    Grid.Column="1">
                    <Label 
                        Grid.Column="1"
                        Text="{Binding Title}"
                        FontAttributes="None"
                        FontSize="18"
                        HorizontalTextAlignment="Start"
                        Margin="20, 0, 0, 0"
                        VerticalTextAlignment="Center"/>
                </Grid>
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <Shell.FlyoutHeader>
        <StackLayout BackgroundColor="{StaticResource FabColor}">
            <Grid ColumnDefinitions="0.9*,0.1*">
                <Label Text="Welcome to Letter Bot!"
                    FontSize="15"
                    HorizontalOptions="Start"
                    Margin="30, 200, 0, 0"
                    FontAttributes="None"
                    TextColor="{StaticResource WhiteColor}" />
                <Image Source="automation_62dp_white.png"
                    HorizontalOptions="End"
                    HeightRequest="62"
                    Margin="0, 162, 0, 20" />
            </Grid>
        </StackLayout>
    </Shell.FlyoutHeader>

    <ShellContent 
        Title="Home" 
        Icon="home_app_logo_62dp_letter.png"
        ContentTemplate="{DataTemplate views:HomeView}"/>

    <MenuItem Text="Bot"
              x:DataType="locals:AppShell"
              IconImageSource="contacts_product_62dp_letter.png"
              Command="{Binding BotCommand}"/>

    <MenuItem Text="Exit"
              x:DataType="locals:AppShell"
              IconImageSource="exit_to_app_62dp_letter.png"
              Command="{Binding ExitCommand}"/>

</Shell>
