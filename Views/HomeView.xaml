<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewmodels="clr-namespace:LetterStomach.ViewModels"
             xmlns:templates="clr-namespace:LetterStomach.Views.Templates"
             x:Class="LetterStomach.Views.HomeView">
    <ContentPage.ToolbarItems>
        <ToolbarItem 
            Text="Settings"
            Priority="1"
            Order="Secondary"
            Clicked="OnSettingClicked"/>
    </ContentPage.ToolbarItems>
    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="{StaticResource LetterColor}" StatusBarStyle="LightContent" />
    </ContentPage.Behaviors>
    <ContentPage.Resources>
        <ResourceDictionary>
        </ResourceDictionary>
    </ContentPage.Resources>
    <ContentPage.Content>
        <Grid      
            BackgroundColor="{StaticResource LetterColor}"
            RowDefinitions="20, *, 150">
            <Grid
                Grid.Row="0"
                RowDefinitions="Auto, *">
            </Grid>
            <Grid
                Grid.Row="1">
                <BoxView
                    Style="{StaticResource ChatHomeBoxViewStyle}"/>
                <CollectionView
                    ItemsSource="{Binding RecentChat}"
                    x:DataType="viewmodels:HomeViewModel"
                    Style="{StaticResource ChatHomeCollectionViewStyle}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <templates:HomeItemTemplate/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
            <Grid 
                Grid.Row="2">
                <Grid
                    ColumnDefinitions="*, 150"
                    BackgroundColor="{StaticResource WhiteColor}">
                    <Border StrokeThickness="1"
                        Stroke="{StaticResource ModalColor}">
                        <Grid
                        Grid.Column="0"
                        Padding="16, 4, 4, 16">
                            <BoxView
                            x:Name="boxDirection"
                            BackgroundColor="{StaticResource MessageColor}">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer 
                                    Command="{Binding SpeakCommand}"/>
                                    <SwipeGestureRecognizer 
                                    Direction="Up" 
                                    Command="{Binding SwipedCommand}" 
                                    CommandParameter="{x:Static SwipeDirection.Up}"/>
                                    <SwipeGestureRecognizer 
                                    Direction="Right" 
                                    Command="{Binding SwipedCommand}" 
                                    CommandParameter="{x:Static SwipeDirection.Right}" />
                                    <SwipeGestureRecognizer 
                                    Direction="Left" 
                                    Command="{Binding SwipedCommand}" 
                                    CommandParameter="{x:Static SwipeDirection.Left}" />
                                    <SwipeGestureRecognizer 
                                    Direction="Down" 
                                    Command="{Binding SwipedCommand}" 
                                    CommandParameter="{x:Static SwipeDirection.Down}" />
                                </BoxView.GestureRecognizers>
                            </BoxView>
                        </Grid>
                    </Border>
                    <Grid 
                        Grid.Column="1"
                        BackgroundColor="{StaticResource WhiteColor}">
                        <Grid>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HomeViewModel}}, Path=BotCommand}"/>
                            </Grid.GestureRecognizers>
                            <Grid 
                                Style="{StaticResource NewBotHomeGridStyle}">
                                <Ellipse   
                                    Fill="{StaticResource LetterColor}"/>
                                <Image
                                    Style="{StaticResource NewBotHomeImageStyle}"
                                    Source="contacts_product_62dp_white.png"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </ContentPage.Content>
</ContentPage>