<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:LetterStomach.Models"
             xmlns:controls="clr-namespace:LetterStomach.Helpers"
             x:Class="LetterStomach.Views.Templates.SenderBotItemTemplate">
    <ContentView.Resources>
        <ResourceDictionary>
        </ResourceDictionary>
    </ContentView.Resources>
    <ContentView.Content>
        <Grid
            ColumnDefinitions="Auto, *, Auto"
            Style="{StaticResource ContainerSenderBotItemGridStyle}"> 
            <Grid
                Style="{StaticResource ShapeSenderBotItemGridStyle}"> 
                <Ellipse
                    x:DataType="models:Message"
                    Background="{Binding Sender.Color, Converter={StaticResource ColorToBrushConverter}}"
                    Style="{StaticResource SenderBotItemEllipseStyle}"/> 
                <Image
                    x:DataType="models:Message"
                    Source="{Binding Sender.Image}"
                    Style="{StaticResource SenderBotItemImageStyle}"/> 
            </Grid>
            <Grid
                Grid.Column="1">
                <BoxView
                    Style="{StaticResource SenderBotItemBoxViewStyle}" /> 
                <Label 
                    Text="{Binding Text}"
                    Style="{StaticResource SenderBotItemLabelStyle}"/> 
            </Grid>
        </Grid>
    </ContentView.Content>
</ContentView>