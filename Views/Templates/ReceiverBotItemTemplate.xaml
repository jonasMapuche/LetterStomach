<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:LetterStomach.Models"
             x:Class="LetterStomach.Views.Templates.ReceiverBotItemTemplate">
    <ContentView.Resources>
        <ResourceDictionary>
        </ResourceDictionary>
    </ContentView.Resources>
    <ContentView.Content>
        <Grid
            ColumnDefinitions="Auto, *"
            Style="{StaticResource ContainerReceiverBotItemGridStyle}"> 
            <Grid 
                Grid.Column="1">
                <BoxView
                    Style="{StaticResource ShapeReceiverBotItemBoxViewStyle}" /> 
                <Label 
                    x:DataType="models:Message"
                    Text="{Binding Text}"
                    Padding="12"
                    Style="{StaticResource MessageReceiverBotItemLabelStyle}"/> 
            </Grid>
        </Grid>
    </ContentView.Content>
</ContentView>